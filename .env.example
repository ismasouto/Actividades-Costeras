# Copia este archivo a .env y ajusta los valores.
# Ejemplo: cp .env.example .env

# PostgreSQL
POSTGRES_USER=costa
POSTGRES_PASSWORD=costa_secret
POSTGRES_DB=costa

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Identificador de ubicación en BD (la app solo recomienda para A Coruña)
LOCATION_ID=a_coruna
